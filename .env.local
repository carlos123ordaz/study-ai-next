# Next.js requires NEXT_PUBLIC_ prefix for client-side env vars
# (previously VITE_ prefix in the React/Vite project)

NEXT_PUBLIC_API_URL=http://localhost:4001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# In production (Vercel / your host), set these to real values:
# NEXT_PUBLIC_API_URL=https://api.studyai.com
# NEXT_PUBLIC_SITE_URL=https://studyai.com
